# Copy this file to .env and fill in your own values for local development.
# Never commit the real .env file — it's already in .gitignore.

# Admin panel
ADMIN_PASSWORD=choose-a-strong-password
JWT_SECRET=choose-a-long-random-string

# Razorpay — get these from the Razorpay Dashboard > Settings > API Keys.
# Use your TEST mode keys (rzp_test_...) until you've verified the full
# checkout flow end-to-end. Only switch to LIVE keys (rzp_live_...) once
# your Razorpay account is KYC-verified and you've tested with test keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret

# Google Sign-In — get this from Google Cloud Console > APIs & Services >
# Credentials > Create Credentials > OAuth client ID (type "Web application").
# Add your site's URL (e.g. http://localhost:3000 and your Render URL) under
# "Authorized JavaScript origins". No client secret is needed — only the
# Client ID, since this uses Google's ID-token verification flow.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
